generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  twoFactorSecret String?
  isLocked     Boolean        @default(false)
  lockedUntil  DateTime?
  roleId       String
  role         Role           @relation(fields: [roleId], references: [id])
  refreshTokens RefreshToken[]
  sessions      AdminSession[]
  loginAttempts LoginAttempt[]
  auditLogs    AuditLog[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Role {
  id          String       @id @default(cuid())
  name        String       @unique
  users       User[]
  permissions Permission[]
}

model Permission {
  id      String @id @default(cuid())
  action  String
  subject String
  roles   Role[]

  @@unique([action, subject])
}

model AdminSession {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionHash String  @unique
  csrfHash    String
  ipAddress   String?
  userAgent   String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime @default(now())
}

model LoginAttempt {
  id        String   @id @default(cuid())
  email     String
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  userAgent String?
  success   Boolean
  reason    String?
  createdAt DateTime @default(now())

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
}

model Notice {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  body        String
  category    String
  pinned      Boolean   @default(false)
  publishAt   DateTime
  expireAt    DateTime?
  attachments Media[]
  translations NoticeTranslation[]
  seoId       String?
  seo         Seo?      @relation(fields: [seoId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Event {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  body      String
  category  String
  startsAt  DateTime
  endsAt    DateTime?
  albumId   String?
  album     Album?    @relation(fields: [albumId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Page {
  id          String   @id @default(cuid())
  path        String   @unique
  template    String
  status      PublishState @default(DRAFT)
  scheduledAt DateTime?
  sections    PageSection[]
  seoId       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PageSection {
  id        String @id @default(cuid())
  pageId    String
  page      Page   @relation(fields: [pageId], references: [id], onDelete: Cascade)
  sectionKey String
  sortOrder Int
  hidden    Boolean @default(false)
  settings  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Menu {
  id        String @id @default(cuid())
  key       String @unique
  location  String
  items     MenuItem[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MenuItem {
  id        String @id @default(cuid())
  menuId    String
  menu      Menu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  labelKey  String
  href      String
  parentId  String?
  sortOrder Int
  openInNewTab Boolean @default(false)
  enabled   Boolean @default(true)
}

model Album {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  media       Media[]
  events      Event[]
  createdAt   DateTime @default(now())
}

model Media {
  id        String    @id @default(cuid())
  url       String
  publicId  String    @unique
  type      String
  alt       String?
  tags      String[]
  folder    String?
  useForAllLanguages Boolean @default(true)
  variants  MediaVariant[]
  uploads   UploadRecord[]
  albumId   String?
  album     Album?    @relation(fields: [albumId], references: [id])
  notices   Notice[]
  downloads Download[]
  createdAt DateTime  @default(now())
}

model UploadRecord {
  id          String @id @default(cuid())
  mediaId     String?
  media       Media? @relation(fields: [mediaId], references: [id], onDelete: SetNull)
  originalName String
  mimeType    String
  fileSize    Int
  checksum    String
  storageKey  String
  uploadedBy  String?
  virusScanStatus String @default("PENDING")
  createdAt   DateTime @default(now())
}

model Teacher {
  id           String     @id @default(cuid())
  name         String
  qualification String
  experience   String
  subject      String
  email        String?
  departmentId String
  department   Department @relation(fields: [departmentId], references: [id])
  photoUrl     String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model Department {
  id       String    @id @default(cuid())
  name     String    @unique
  teachers Teacher[]
}

model Admission {
  id            String   @id @default(cuid())
  studentName   String
  className     String
  guardianName  String?
  guardianPhone String
  message       String?
  status        String   @default("NEW")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Result {
  id           String   @id @default(cuid())
  studentId    String
  symbolNumber String
  studentName  String
  className    String
  gpa          Float
  remarks      String
  published    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([studentId])
  @@index([symbolNumber])
}

model Download {
  id        String   @id @default(cuid())
  title     String
  category  String
  fileId    String
  file      Media    @relation(fields: [fileId], references: [id])
  translations DownloadTranslation[]
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  body      String
  status    String   @default("UNREAD")
  createdAt DateTime @default(now())
}

model Testimonial {
  id       String @id @default(cuid())
  name     String
  role     String
  quote    String
  photoUrl String?
}

model Achievement {
  id    String @id @default(cuid())
  title String
  year  Int
  body  String
}

model Facility {
  id       String @id @default(cuid())
  title    String
  body     String
  icon     String
  photoUrl String?
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value Json
}

model Seo {
  id          String   @id @default(cuid())
  path        String   @unique
  title       String
  description String
  ogImage     String?
  schema      Json?
  notices     Notice[]
  translations SeoTranslation[]
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model BackupJob {
  id        String @id @default(cuid())
  type      String
  status    String
  storageKey String?
  includesDatabase Boolean @default(true)
  includesMedia    Boolean @default(true)
  startedAt DateTime @default(now())
  finishedAt DateTime?
  createdBy String?
}

model RestoreJob {
  id        String @id @default(cuid())
  backupId  String
  status    String
  requestedBy String?
  startedAt DateTime @default(now())
  finishedAt DateTime?
}

model Language {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  nativeName  String?
  direction   String   @default("ltr")
  isDefault   Boolean  @default(false)
  isEnabled   Boolean  @default(true)
  publicState PublishState @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contentTranslations ContentTranslation[]
  noticeTranslations  NoticeTranslation[]
  downloadTranslations DownloadTranslation[]
  seoTranslations SeoTranslation[]
  mediaVariants MediaVariant[]
}

model ContentItem {
  id          String   @id @default(cuid())
  key         String   @unique
  contentType String
  pagePath    String?
  sectionKey  String?
  fallbackValue String?
  translations ContentTranslation[]
  revisions    ContentRevision[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContentTranslation {
  id        String @id @default(cuid())
  itemId    String
  item      ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  languageId String
  language Language @relation(fields: [languageId], references: [id])
  value     String
  status    PublishState @default(DRAFT)
  scheduledAt DateTime?
  archivedAt  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([itemId, languageId])
}

model ContentRevision {
  id        String @id @default(cuid())
  itemId    String
  item      ContentItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  languageCode String
  oldValue  String?
  newValue  String
  changedBy String?
  createdAt DateTime @default(now())
}

model NoticeTranslation {
  id          String @id @default(cuid())
  noticeId    String
  notice      Notice @relation(fields: [noticeId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language @relation(fields: [languageId], references: [id])
  title       String
  body        String
  category    String
  status      PublishState @default(DRAFT)
  publishAt   DateTime?
  scheduledAt DateTime?
  archivedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([noticeId, languageId])
}

model DownloadTranslation {
  id          String @id @default(cuid())
  downloadId  String
  download    Download @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language @relation(fields: [languageId], references: [id])
  title       String
  fileUrl     String
  filePublicId String?
  status      PublishState @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([downloadId, languageId])
}

model SeoTranslation {
  id          String @id @default(cuid())
  seoId       String
  seo         Seo @relation(fields: [seoId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language @relation(fields: [languageId], references: [id])
  title       String
  description String
  keywords    String[]
  ogTitle     String?
  ogDescription String?
  ogImage     String?
  canonicalUrl String?
  status      PublishState @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([seoId, languageId])
}

model MediaVariant {
  id          String @id @default(cuid())
  mediaId     String
  media       Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  languageId  String
  language    Language @relation(fields: [languageId], references: [id])
  url         String
  publicId    String
  alt         String?
  caption     String?
  status      PublishState @default(DRAFT)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([mediaId, languageId])
}

model TranslationSetting {
  id          String @id @default(cuid())
  key         String @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
}

enum PublishState {
  DRAFT
  PUBLISHED
  SCHEDULED
  ARCHIVED
}
