NODE_ENV=production
PORT=8080
DATABASE_URL=postgresql://cms_user:change-me@localhost:5432/kankai_cms
SESSION_COOKIE_NAME=kss_admin_session
SESSION_SECRET=replace-with-64-random-bytes
CSRF_COOKIE_NAME=kss_csrf
ADMIN_LOGIN_PATH=/kss-secure-cms-gate-83
